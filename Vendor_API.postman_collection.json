{
  "info": {
    "_postman_id": "vendor-api-collection-2026",
    "name": "Vendor API — api/mobile/vendor",
    "description": "Complete Vendor (Service Provider) API endpoints for Farah mobile app.\n\nFlow:\n1. Register → verify OTP → wait for admin approval\n2. Login → use Bearer token for protected routes\n3. Admin must approve vendor before protected routes work\n\nLocation: Vendor profile includes country, city, area, address, latitude, longitude, googleMapsLink. Branches: GET/POST/PATCH/DELETE /api/mobile/vendor/locations.\n\nAdmin: /api/admin/vendors/* (list, get, update, approve, reject, suspend, send-money, transactions, orders). Admin locations: /api/admin/vendors/:id/locations. Map: GET /api/admin/vendors-map.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "exec": [
          "var code = pm.response.code;",
          "pm.test('Status code is 2xx or expected client/error', function() { pm.expect(code).to.be.within(200, 499); });",
          "if (code >= 200 && code < 300) {",
          "  pm.test('Response has body or is no-content', function() {",
          "    if (code !== 204) pm.expect(pm.response.json()).to.be.an('object');",
          "  });",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "vendorToken", "value": "", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "vendorId", "value": "", "type": "string" },
    { "key": "serviceId", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" },
    { "key": "locationId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Vendor Auth",
      "item": [
        {
          "name": "1. Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('vendorToken', res.token);",
                  "  pm.collectionVariables.set('vendorId', res.vendor.id);",
                  "  console.log('OTP (dev):', res.otp);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"محمد أحمد\",\n  \"phone\": \"0501234567\",\n  \"password\": \"secret123\",\n  \"vendorType\": \"RESTAURANT\",\n  \"businessName\": \"مطعم البيت\",\n  \"businessNameAr\": \"مطعم البيت\",\n  \"address\": \"الرياض - حي النرجس\",\n  \"country\": \"الكويت\",\n  \"city\": \"الكويت\",\n  \"area\": \"النرجس\",\n  \"googleMapsLink\": \"https://maps.google.com/?q=29.3759,47.9774\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "auth", "register"]
            },
            "description": "Register a new vendor. vendorType options: RESTAURANT | FASHION_STORE | SWEETS_SHOP | HEADPHONES_RENTAL\n\nReturns JWT token + OTP (in dev mode)"
          }
        },
        {
          "name": "2. Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0501234567\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "auth", "verify-otp"]
            },
            "description": "Verify phone number with the OTP received after registration"
          }
        },
        {
          "name": "3. Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0501234567\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/auth/resend-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "auth", "resend-otp"]
            }
          }
        },
        {
          "name": "4. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('vendorToken', res.token);",
                  "  pm.collectionVariables.set('vendorId', res.vendor.id);",
                  "  console.log('Vendor status:', res.vendor.status);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0501234567\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "auth", "login"]
            },
            "description": "Login returns: token, vendor info, status.\nStatus can be PENDING | APPROVED | REJECTED | SUSPENDED\n⚠️ Protected routes only work when status = APPROVED"
          }
        },
        {
          "name": "5. Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0501234567\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "auth", "forgot-password"]
            }
          }
        },
        {
          "name": "6. Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0501234567\",\n  \"otp\": \"654321\",\n  \"newPassword\": \"newpass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "auth", "reset-password"]
            }
          }
        }
      ]
    },
    {
      "name": "👤 Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{vendorToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "profile"]
            },
            "description": "Returns vendor profile including: name, phone, vendorType, status, businessName, address, country, city, area, latitude, longitude, googleMapsLink, wallet, _count (services, orders)."
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{vendorToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "محمد أحمد المعدل", "type": "text" },
                { "key": "businessName", "value": "مطعم القصر", "type": "text" },
                { "key": "description", "value": "أفضل مطعم في المدينة", "type": "text" },
                { "key": "address", "value": "الرياض - حي العليا", "type": "text" },
                { "key": "country", "value": "الكويت", "type": "text" },
                { "key": "city", "value": "الكويت", "type": "text" },
                { "key": "area", "value": "العليا", "type": "text" },
                { "key": "latitude", "value": "29.3759", "type": "text" },
                { "key": "longitude", "value": "47.9774", "type": "text" },
                { "key": "googleMapsLink", "value": "https://maps.google.com/?q=29.3759,47.9774", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "profile"]
            },
            "description": "Supports multipart/form-data. Add 'avatar' field with image file to update avatar. Location: address, country, city, area, latitude, longitude, googleMapsLink."
          }
        },
        {
          "name": "Update Password",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"secret123\",\n  \"newPassword\": \"newsecret456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/profile/password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "profile", "password"]
            }
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{vendorToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "profile"]
            },
            "description": "⚠️ Permanently deletes the vendor account and all associated data"
          }
        }
      ]
    },
