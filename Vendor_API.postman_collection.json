              "path": ["api", "mobile", "vendor", "services"]
            },
            "description": "Add service/product. Supports multiple image uploads via 'images' field.\nRestaurants: menu items | Fashion: clothing items | Sweets: sweets/cakes | Headphones: rental units"
          }
        },
        {
