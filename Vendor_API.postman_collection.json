    {
      "name": "📦 Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{vendorToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/orders?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "PENDING", "disabled": true }
              ]
            },
            "description": "Filter by status: PENDING | ACCEPTED | REJECTED | IN_DELIVERY | DELIVERED | CANCELLED"
          }
        },
        {
          "name": "Get Order by ID",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.collectionVariables.get('orderId')) {",
                  "  pm.variables.set('orderId', 'REPLACE_WITH_ORDER_ID');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{vendorToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "orders", "{{orderId}}"]
            }
          }
        },
        {
          "name": "Accept Order",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{vendorToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/orders/{{orderId}}/accept",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "orders", "{{orderId}}", "accept"]
            },
            "description": "Accept a PENDING order"
          }
        },
        {
          "name": "Reject Order",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"المنتج غير متوفر حالياً\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/orders/{{orderId}}/reject",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "orders", "{{orderId}}", "reject"]
            }
          }
        },
        {
          "name": "Update Order Status → IN_DELIVERY",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_DELIVERY\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/orders/{{orderId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "orders", "{{orderId}}", "status"]
            }
          }
        },
        {
          "name": "Update Order Status → DELIVERED (credits wallet)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DELIVERED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mobile/vendor/orders/{{orderId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mobile", "vendor", "orders", "{{orderId}}", "status"]
            },
            "description": "Setting status to DELIVERED automatically credits the order amount to the vendor wallet"
          }
        }
      ]
